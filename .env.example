APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Content-Security-Policy + other security headers on web + admin + API. Set false if local Vite HMR is blocked.
# SECURITY_CSP_ENABLED=true
# Optional extra connect-src origins (comma-separated)
# SECURITY_CSP_CONNECT_EXTRA=

# SEO (public pages). APP_URL must be the canonical HTTPS origin in production.
# SEO_OG_IMAGE must be an absolute URL to a raster image (1200×630 PNG/JPG) for best social previews.
# SEO_TWITTER_HANDLE = username without @
# SEO_GOOGLE_SITE_VERIFICATION = content value from Search Console HTML tag method
# SEO_MS_VALIDATE = Bing Webmaster Tools meta content
# GA4 production analytics (only loads after visitor consent in this app)
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# SEO_OG_IMAGE=
# SEO_OG_IMAGE_WIDTH=1200
# SEO_OG_IMAGE_HEIGHT=630
# SEO_TWITTER_HANDLE=
# SEO_GOOGLE_SITE_VERIFICATION=
# SEO_MS_VALIDATE=
# SEO_THEME_COLOR=#060a12

# Display & PHP default timezone (DB timestamps stay UTC). Use an IANA name, e.g. America/New_York
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database

# Production: prefixed session cookies (__Host- when path=/ and SESSION_DOMAIN empty; else __Secure-).
# Requires HTTPS: SESSION_SECURE_COOKIE=true
# SESSION_COOKIE_HOST_PREFIX=true
# SESSION_SECURE_COOKIE=true
# SESSION_DOMAIN=
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# otshare.io (set APP_NAME=otshare.io, APP_URL to your production URL)
# Production: set APP_ENV=production, APP_DEBUG=false, SESSION_SECURE_COOKIE=true
# ---------------------------------------------------------------------------

# Max upload size (bytes). Default 100MB.
# OTSHARE_MAX_FILE_SIZE=104857600

# Share expiry (minutes), max downloads per share, download token validity (minutes).
# OTSHARE_EXPIRY_MINUTES=30
# OTSHARE_MAX_DOWNLOADS=1
# OTSHARE_TOKEN_EXPIRY_MINUTES=5

# Redeem lock after N failed attempts, lock duration (minutes).
# OTSHARE_REDEEM_LOCK_AFTER=5
# OTSHARE_REDEEM_LOCK_MINUTES=15

# Max wrong passcode attempts before file is permanently deleted.
# OTSHARE_MAX_PASSCODE_ATTEMPTS=3

# Storage disk for encrypted files: local or s3 (set FILESYSTEM_DISK / AWS_* for s3).
# OTSHARE_STORAGE_DISK=local

# Rate limits (per minute per IP): shares, upload, redeem, download, confirm.
# OTSHARE_RATE_LIMIT_SHARES=30
# OTSHARE_RATE_LIMIT_UPLOAD=20
# OTSHARE_RATE_LIMIT_REDEEM=15
# OTSHARE_RATE_LIMIT_DOWNLOAD=30
# OTSHARE_RATE_LIMIT_CONFIRM=20

# Hidden admin: create credential with
#   php artisan otshare:admin-create "ops" "your-dashboard-password"
# then set the printed key here (must match the key you use in ?key= / X-Admin-Key).
# OTSHARE_ADMIN_SECRET=
#
# Comma-separated IPs or CIDRs allowed to hit /admin (e.g. 203.0.113.10,10.0.0.0/24,::1).
# Empty: any IP in local/testing; in production empty = admin disabled (404).
# OTSHARE_ADMIN_ALLOWED_IPS=127.0.0.1,::1
#
# Behind a reverse proxy, configure trusted proxies so the allowlist sees the real client IP (see Laravel docs).
#
# Admin uses a separate session cookie (otshare_admin_session) that expires when the browser closes.
# While the browser stays open, TOTP trust duration (hours):
# OTSHARE_ADMIN_MFA_SESSION_HOURS=12
#
# Purge all shares + tokens + stored files: php artisan otshare:purge-all (--force for non-interactive).
# Admin access logs (admin_access_logs) are never deleted by purge.
